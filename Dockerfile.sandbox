FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        python3 \
        python3-pip \
        python3-venv \
        nodejs \
        npm \
        strace \
 && pip3 install --no-cache-dir --break-system-packages setuptools wheel \
 && apt-get clean \
 && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --shell /bin/bash deton

USER deton
WORKDIR /home/deton
